/**
 * @description       : Unit tests for CaseHandler adapted to org constraints (required fields + OnCase trigger)
 * @author            : Generated by Agentforce
 * @date              : 2025-11-18
 */
@IsTest
private class CaseHandlerTest {

    // --- Test Data Builders (respect org required fields and trigger behavior) ---

    private static Account createHotel(String name, String externalKey) {
        Account a = new Account(Name = name);
        // ExternalId__c required for routing mapping in org
        try { a.put('ExternalId__c', externalKey); } catch (Exception ignore) {}
        insert a;
        return a;
    }

    private static Contact createGuest(Account hotel) {
        Contact c = new Contact(FirstName = 'Test', LastName = 'Guest', AccountId = hotel.Id);
        insert c;
        return c;
    }

    // Room__c requires RoomNumber__c and ExternalId__c in this org
    private static SObject createRoom(Account hotel, String roomNumber, String roomExternalId) {
        SObject room = (SObject) Type.forName('Room__c').newInstance();
        try { room.put('Name', 'Room ' + roomNumber); } catch (Exception ignore) {}
        try { room.put('RoomNumber__c', roomNumber); } catch (Exception ignore) {}
        try { room.put('ExternalId__c', roomExternalId); } catch (Exception ignore) {}
        try { room.put('Hotel__c', hotel.Id); } catch (Exception ignore) {}
        insert room;
        return room;
    }

    private static SObject createBooking(Contact guest, SObject room) {
        SObject booking = (SObject) Type.forName('Booking__c').newInstance();
        try { booking.put('Name', 'BK-' + String.valueOf(Crypto.getRandomInteger()).replace('-', '')); } catch (Exception ignore) {}
        try { booking.put('Guest__c', guest.Id); } catch (Exception ignore) {}
        try { booking.put('Room__c', (Id) room.get('Id')); } catch (Exception ignore) {}
        insert booking;
        return booking;
    }

    private static Pricebook2 ensureHotelPricebook(Account hotel) {
        Pricebook2 pb = new Pricebook2(Name = 'Hotel PB ' + hotel.Name, IsActive = true);
        try { pb.put('HotelId__c', hotel.Id); } catch (Exception ignore) {}
        insert pb;
        return pb;
    }

    // Create Queue with DeveloperName matching Account.ExternalId__c
    private static Group createQueueForExternalKey(String developerName) {
        String dn = developerName;
        if (String.isBlank(dn)) {
            dn = 'HOTEL_' + String.valueOf(Crypto.getRandomInteger()).replace('-', '');
        }
        Group g = new Group(Type = 'Queue', Name = dn, DeveloperName = dn);
        insert g;
        return g;
    }

    // Case factory that respects OnCase before-insert trigger requiring AccountId
    private static Case newCaseRespectingTrigger(Account hotel, Id bookingId) {
        Case c = new Case(Subject = 'Test Case', Origin = 'Web', Status = 'New', AccountId = hotel.Id);
        // Populate BookingId__c if available for fillRelatedAccount scenarios
        if (bookingId != null) {
            try { c.put('BookingId__c', bookingId); } catch (Exception ignore) {}
        }
        return c;
    }

    // --- Tests ---

    @IsTest
    static void test_fillRelatedAccount_setsAccountAndContact_fromBooking() {
        // Arrange
        Account hotel = createHotel('Hotel A', 'HOTEL_A_EXT');
        Contact guest = createGuest(hotel);
        SObject room = createRoom(hotel, '101', 'ROOM_A_101');
        SObject booking = createBooking(guest, room);

        // Insert cases with AccountId set to satisfy before-insert trigger
        Case c1 = newCaseRespectingTrigger(hotel, (Id) booking.get('Id'));
        Case c2 = newCaseRespectingTrigger(hotel, (Id) booking.get('Id'));
        insert new List<Case>{ c1, c2 };

        List<Case> cases = [SELECT Id, AccountId, ContactId, BookingId__c FROM Case WHERE Id IN :new List<Id>{c1.Id, c2.Id} WITH SECURITY_ENFORCED];

        // Act
        Test.startTest();
        CaseHandler.fillRelatedAccount(cases);
        Test.stopTest();

        // Assert: Account and Contact filled from booking
        for (Case c : cases) {
            System.assertEquals(hotel.Id, c.AccountId, 'AccountId should be set from Booking.Room__r.Hotel__c');
            System.assertEquals(guest.Id, c.ContactId, 'ContactId should be set from Booking.Guest__c');
        }
    }

    @IsTest
    static void test_createLinkedOrder_createsOrder_and_backfills_OrderId_onCase() {
        // Arrange
        Account hotel = createHotel('Hotel B', 'HOTEL_B_EXT');
        ensureHotelPricebook(hotel);

        // Insert cases WITH AccountId to satisfy before-insert trigger and allow createLinkedOrder mapping
        Case c1 = newCaseRespectingTrigger(hotel, null);
        Case c2 = newCaseRespectingTrigger(hotel, null);
        insert new List<Case>{ c1, c2 };

        List<Case> cases = [SELECT Id, AccountId FROM Case WHERE Id IN :new List<Id>{c1.Id, c2.Id} WITH SECURITY_ENFORCED];

        // Act
        Test.startTest();
        CaseHandler.createLinkedOrder(cases);
        Test.stopTest();

        // Assert: each Case has Order created and backfilled
        Set<Id> orderIds = new Set<Id>();
        for (Case c : cases) {
            Id orderId = (Id) c.get('OrderId__c');
            System.assertNotEquals(null, orderId, 'OrderId__c must be populated on Case');
            orderIds.add(orderId);
        }
        List<Order> created = [SELECT Id, AccountId, Status, Pricebook2Id, EffectiveDate FROM Order WHERE Id IN :orderIds];
        System.assertEquals(2, created.size(), 'Two orders should have been created');
        for (Order o : created) {
            System.assertEquals(hotel.Id, o.AccountId, 'Order.AccountId must match Case.AccountId');
            System.assertEquals('Draft', o.Status, 'Order.Status must be Draft');
            System.assertNotEquals(null, o.Pricebook2Id, 'Order must have a Pricebook2Id');
            System.assertEquals(Date.today(), o.EffectiveDate, 'EffectiveDate should be today');
        }
    }

    @IsTest
    static void test_routeCaseToHotelQueue_routes_on_status_change_from_Web_origin() {
        // Arrange
        Account hotel = createHotel('Hotel C', 'HOTEL_C_EXT');
        Group q = createQueueForExternalKey((String) hotel.get('ExternalId__c'));

        User u = [SELECT Id FROM User WHERE IsActive = true LIMIT 1];
        Case c = newCaseRespectingTrigger(hotel, null);
        c.OwnerId = u.Id;
        insert c;

        // OldMap and newList reflecting status change to InProgress
        Case oldC = c.clone(false, true, false, false);
        Map<Id, Case> oldMap = new Map<Id, Case>{ c.Id => oldC };
        c.Status = 'InProgress';
        List<Case> newList = new List<Case>{ c };

        // Act
        Test.startTest();
        CaseHandler.routeCaseToHotelQueue(newList, oldMap);
        Test.stopTest();

        // Assert
        System.assertEquals(q.Id, c.OwnerId, 'Case should be routed to the hotel queue when status changes to InProgress and origin is Web');
    }

    @IsTest
    static void test_routeCaseToHotelQueue_noop_when_not_inprogress_or_non_web() {
        // Arrange
        Account hotel = createHotel('Hotel D', 'HOTEL_D_EXT');
        Group q = createQueueForExternalKey((String) hotel.get('ExternalId__c'));

        // Scenario 1: Origin not Web
        Case c1 = newCaseRespectingTrigger(hotel, null);
        c1.Origin = 'Phone';
        insert c1;
        Case old1 = c1.clone(false, true, false, false);
        Map<Id, Case> oldMap1 = new Map<Id, Case>{ c1.Id => old1 };
        c1.Status = 'InProgress';
        List<Case> list1 = new List<Case>{ c1 };

        // Scenario 2: Status unchanged
        Case c2 = newCaseRespectingTrigger(hotel, null);
        insert c2;
        Case old2 = c2.clone(false, true, false, false);
        Map<Id, Case> oldMap2 = new Map<Id, Case>{ c2.Id => old2 };
        List<Case> list2 = new List<Case>{ c2 };

        // Act
        Test.startTest();
        CaseHandler.routeCaseToHotelQueue(list1, oldMap1);
        CaseHandler.routeCaseToHotelQueue(list2, oldMap2);
        Test.stopTest();

        // Assert
        System.assertNotEquals(q.Id, c1.OwnerId, 'Origin != Web: should not route');
        System.assertEquals('InProgress', c1.Status, 'Control: status updated on case 1');
        System.assertEquals('New', c2.Status, 'Control: status unchanged on case 2');
        System.assertNotEquals(q.Id, c2.OwnerId, 'Status unchanged: should not route');
    }

    @IsTest
    static void test_bulk_behavior_all_methods_handle_multiple_records() {
        // Arrange
        Account hotel = createHotel('Hotel E', 'HOTEL_E_EXT');
        Contact guest = createGuest(hotel);
        SObject room = createRoom(hotel, '201', 'ROOM_E_201');
        SObject booking = createBooking(guest, room);
        ensureHotelPricebook(hotel);

        // Prepare 5 cases (AccountId set to satisfy trigger), with BookingId to allow fillRelatedAccount
        List<Case> casesToInsert = new List<Case>();
        for (Integer i = 0; i < 5; i++) {
            casesToInsert.add(newCaseRespectingTrigger(hotel, (Id) booking.get('Id')));
        }
        insert casesToInsert;

        // Reload cases
        List<Case> cases = [SELECT Id, AccountId, Origin, Status, BookingId__c FROM Case WHERE Id IN :casesToInsert WITH SECURITY_ENFORCED];

        // Prepare oldMap and set new status/origin to meet routing criteria
        Map<Id, Case> oldMap = new Map<Id, Case>();
        for (Case c : cases) {
            oldMap.put(c.Id, c.clone(false, true, false, false));
            c.Status = 'InProgress';
            c.Origin = 'Web';
        }

        // Create matching queue for routing
        Group q = createQueueForExternalKey((String) hotel.get('ExternalId__c'));

        // Act
        Test.startTest();
        CaseHandler.fillRelatedAccount(cases);
        CaseHandler.createLinkedOrder(cases);
        CaseHandler.routeCaseToHotelQueue(cases, oldMap);
        Test.stopTest();

        // Assert
        Set<Id> orderIds = new Set<Id>();
        for (Case c : cases) {
            System.assertEquals(hotel.Id, c.AccountId, 'AccountId must be filled for each case');
            System.assertNotEquals(null, c.get('ContactId'), 'ContactId must be filled for each case');
            Id orderId = (Id) c.get('OrderId__c');
            System.assertNotEquals(null, orderId, 'OrderId__c must be set on each case');
            orderIds.add(orderId);
            System.assertEquals(q.Id, c.OwnerId, 'Owner should be queue after routing');
        }
        System.assertEquals(5, orderIds.size(), 'An order should have been created for each case');
    }
}
